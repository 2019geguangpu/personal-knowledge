# SiliconFlow（OpenAI 兼容）
# 在 https://siliconflow.cn 获取 API Key
SILICONFLOW_API_KEY=

# 本地 LanceDB 目录（相对项目根目录或绝对路径）
VECTOR_DB_PATH=./data/lancedb

# 可选：覆盖默认模型（嵌入须为文档所列之一，见 create-embeddings）
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Qwen3 系列可指定输出维度（默认 1024）；改维度后需清空向量库并重新导入
# SILICONFLOW_EMBEDDING_DIMENSIONS=1024
# SILICONFLOW_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# 飞书开放平台自建应用（用于 /api/feishu/import 拉取 docx 纯文本）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
