# SiliconFlow（OpenAI 兼容）
# 在 https://siliconflow.cn 获取 API Key
SILICONFLOW_API_KEY=

# 本地 LanceDB 目录（相对项目根目录或绝对路径）
VECTOR_DB_PATH=./data/lancedb

# 法律案例：来源核验分级（逗号分隔 host；支持 *.court.gov.cn 这类前缀通配）
# A：官方源（通过则可入库/引用）
LAW_SOURCE_ALLOWLIST_OFFICIAL=
# B：权威源（通过则可入库/引用，但 UI 会标注“非官网”）
LAW_SOURCE_ALLOWLIST_TRUSTED=
#
# 兼容旧版（单一白名单）；若配置了 OFFICIAL/TRUSTED，可不填
LAW_SOURCE_ALLOWLIST=

# SerpAPI（全网搜索候选 URL；按调用次数计费，免费计划每月有一定额度）
SERPAPI_API_KEY=

# 可选：覆盖默认模型（嵌入须为文档所列之一，见 create-embeddings）
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Qwen3 系列可指定输出维度（默认 1024）；改维度后需清空向量库并重新导入
# SILICONFLOW_EMBEDDING_DIMENSIONS=1024
# SILICONFLOW_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# 飞书开放平台自建应用（用于 /api/feishu/import 拉取 docx 纯文本）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# NestJS skill-runner（Next 仅转发：/api/skills、/api/skills/run、/api/skills/install-zip 等）
# SKILL_RUNNER_URL=http://127.0.0.1:4317
