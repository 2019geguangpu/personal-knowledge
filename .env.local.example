# 复制为 .env.local 后填写：
# cp .env.local.example .env.local

SILICONFLOW_API_KEY=your_siliconflow_api_key_here
VECTOR_DB_PATH=./data/lancedb

# 可选（嵌入模型须符合 SiliconFlow create-embeddings 文档枚举）
